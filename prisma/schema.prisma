generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [uuid_ossp(map: "uuid-ossp", schema: "extensions"), vector]
}

model Card {
  id               Int           @id @default(autoincrement())
  card_id          Int?          @unique
  name             String
  name_en          String?
  name_vi          String?
  number           Int
  arcana           String
  suit             String?
  image            String?
  description      String?
  detailed_meaning String?
  upright          String[]
  reversed         String[]
  keywords         String[]
  element          String?
  zodiac           String?
  yes_no           String?
  slug             String        @unique
  meanings         CardMeaning[]

  @@index([arcana])
  @@index([element])
  @@index([slug])
}

model CardMeaning {
  id        Int                    @id @default(autoincrement())
  card_id   Int
  category  String
  content   String
  embedding Unsupported("vector")?
  card      Card                   @relation(fields: [card_id], references: [card_id])

  @@index([card_id])
  @@index([category])
}

model ReadingSession {
  id             String   @id @default(uuid())
  user_question  String
  selected_topic String
  picked_cards   String
  ai_response    String
  created_at     DateTime @default(now())

  @@index([created_at])
}
